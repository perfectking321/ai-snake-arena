      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--panel-border);
      border-radius: 12px;
      padding: 1rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .stat-label {
      font-size: 0.7rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.5rem;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .stat-value.accent { color: var(--section-accent); }

    /* Each section defines --section-accent locally */
    #sec-dqn { --section-accent: var(--color-dqn); }
    #sec-bfs { --section-accent: var(--color-bfs); }
    #sec-dfs { --section-accent: var(--color-dfs); }
    #sec-ucs { --section-accent: var(--color-ucs); }
    #sec-astar { --section-accent: var(--color-astar); }
    #sec-bestfirst { --section-accent: var(--color-bestfirst); }
    #sec-minimax { --section-accent: var(--color-minimax); }

